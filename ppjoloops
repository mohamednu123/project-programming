class Order{
//  array to store el order and elkmeh for on item
private:
    food orders[40];
    int quantity[40];
    int count = 0;
public:
    // function to add order by arranged in array
    void addorder(food item, int qty)
    {
        orders[count] = item;
        quantity[count] = qty;
        count++;
    }
    // function to show the chooeses of customar from items  with price
    void showorder(){
        float total = 0;
        cout << "\nThis is your order:\n";
        //loop for print many order items with price
        for(int i = 0; i < count; i++)
        {
            cout << i + 1 << "--" // print num of order
                 << orders[i].findname()
                 << " x " << quantity[i]
                 << " ==> "
                 << orders[i].findprice() <<" x " << quantity[i]
                 << " l.e" << endl;
            total += orders[i].findprice() * quantity[i];
        }
        cout << "\nTotal Price = " << total << " l.e" << endl;
    }
};
